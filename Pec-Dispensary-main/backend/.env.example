# =============================================
# SUPABASE CONFIGURATION
# =============================================
# Get these from your Supabase Dashboard:
# 1. Go to https://app.supabase.com
# 2. Select your project
# 3. Go to Settings > API
# 4. Copy the values below

# Your Supabase project URL (starts with https://)
SUPABASE_URL=your_supabase_project_url_here

# Your Supabase anon/public key (for frontend - optional)
SUPABASE_ANON_KEY=your_supabase_anon_key_here

# Your Supabase service_role key (for backend - REQUIRED)
# ⚠️ KEEP THIS SECRET! Never expose in frontend code
SUPABASE_SERVICE_ROLE_KEY=your_supabase_service_role_key_here

# =============================================
# JWT CONFIGURATION
# =============================================
# Secret key for signing JWT tokens (use a strong random string)
JWT_SECRET=your_jwt_secret_key_here

# =============================================
# SERVER CONFIGURATION
# =============================================
PORT=4000

# =============================================
# EXAMPLE VALUES (REPLACE WITH YOUR ACTUAL VALUES):
# =============================================
# SUPABASE_URL=https://abcdefghijklmnop.supabase.co
# SUPABASE_ANON_KEY=eyJhbGciOiJIUzI1NiIsInR5cCI6IkpXVCJ9...
# SUPABASE_SERVICE_ROLE_KEY=eyJhbGciOiJIUzI1NiIsInR5cCI6IkpXVCJ9...
# JWT_SECRET=my-super-secret-jwt-key-change-this-in-production
